# ─────────────────────────────────────────────────────────────────
# CRM Platform — Environment Variables
# Salin file ini ke .env dan isi semua nilai sebelum deploy.
# JANGAN commit file .env ke git!
# ─────────────────────────────────────────────────────────────────

# ─── DATABASE ────────────────────────────────────────────────────

# URL koneksi ke Master DB (PostgreSQL)
# Di Railway: copy dari plugin PostgreSQL → "DATABASE_URL"
# Format: postgresql://user:password@host:port/crm_master
DATABASE_URL=postgresql://user:password@host:5432/crm_master

# ─── AUTH & SESSION ──────────────────────────────────────────────

# Secret untuk JWT session cookie — wajib random dan panjang di production
# Generate: openssl rand -base64 32
JWT_SECRET=ganti-dengan-random-string-panjang

# Secret untuk NextAuth (dipakai di beberapa helper) — boleh sama dengan JWT_SECRET
NEXTAUTH_SECRET=ganti-dengan-random-string-panjang

# URL publik aplikasi (tanpa trailing slash)
# Di Railway: pakai URL yang Railway berikan, misal https://crm-platform.up.railway.app
NEXTAUTH_URL=https://crm-platform.up.railway.app

# ─── PUBLIC URLS ─────────────────────────────────────────────────

# URL publik yang diekspos ke client-side (harus sama dengan NEXTAUTH_URL)
NEXT_PUBLIC_APP_URL=https://crm-platform.up.railway.app
NEXT_PUBLIC_BASE_URL=https://crm-platform.up.railway.app

# ─── REDIS (BullMQ — Sapaan Worker) ─────────────────────────────

# URL koneksi ke Redis
# Di Railway: copy dari plugin Redis → "REDIS_URL"
# Format: redis://default:password@host:port
REDIS_URL=redis://default:password@host:6379

# ─── EMAIL (Resend) ───────────────────────────────────────────────

# API key dari resend.com — untuk email password reset dll
# Daftar di resend.com, buat API key, daftarkan domain meditech.my.id
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── WEB PUSH NOTIFICATIONS (VAPID) ─────────────────────────────

# Generate keypair: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:admin@meditech.my.id

# ─── AI (Claude / Anthropic) ─────────────────────────────────────

# API key untuk fitur AI (NLP search, suggested reply, dll)
# Dari: console.anthropic.com
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── PLATFORM ────────────────────────────────────────────────────

# Domain utama platform (dipakai middleware untuk deteksi tenant)
# Di Railway: isi dengan domain Railway atau custom domain kamu
PLATFORM_DOMAIN=crm-platform.up.railway.app

# Timezone (jangan diubah)
TZ=Asia/Jakarta

# ─── SAPAAN WORKER ───────────────────────────────────────────────

# Set ke "true" hanya saat testing — pesan tidak benar-benar dikirim ke WA
# Di production Railway: HAPUS atau set ke "false"
SAPAAN_DRY_RUN=false
