{
  "name": "crm-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build && cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "start": "next start",
    "lint": "next lint",
    "worker": "tsx --tsconfig tsconfig.json src/workers/index.ts",
    "worker:dev": "tsx watch --tsconfig tsconfig.json src/workers/index.ts",
    "worker:start": "node --import tsx/esm src/workers/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "dotenv": "^16.4.7",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "next": "14.2.35",
    "pg": "^8.22.0",
    "prisma": "^6.19.3",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.7.0",
    "resend": "^6.16.0",
    "tsx": "^4.23.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "mysql2": "^3.22.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
